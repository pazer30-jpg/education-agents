# ─────────────────────────────────────────────
# Moki — Education Agents Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─────────────────────────────────────────────
# Claude API (required if NOT using Claude CLI)
# ─────────────────────────────────────────────
# אם אתה רץ דרך claude CLI (מנוי) — אל תמלא.
# אם אתה רץ דרך API key ישיר — חובה.
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Telegram Bot (from @BotFather)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: restrict to specific user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=

# ─────────────────────────────────────────────
# Academic APIs
# ─────────────────────────────────────────────
# Semantic Scholar (optional — improves rate limits)
# Get free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Unpaywall (uses your email for API access — required)
UNPAYWALL_EMAIL=pazer30@gmail.com
