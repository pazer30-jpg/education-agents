# ─────────────────────────────────────────────
# Moki — Education Agents Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─────────────────────────────────────────────
# Claude API (required if NOT using Claude CLI)
# ─────────────────────────────────────────────
# אם אתה רץ דרך claude CLI (מנוי) — אל תמלא.
# אם אתה רץ דרך API key ישיר — חובה.
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Telegram Bot (from @BotFather)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: restrict to specific user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=

# ─────────────────────────────────────────────
# Academic APIs
# ─────────────────────────────────────────────
# Semantic Scholar (optional — improves rate limits)
# Get free key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Unpaywall (uses your email for API access — required)
UNPAYWALL_EMAIL=your-email@example.com

# ─────────────────────────────────────────────
# fal.ai — Video generation (Agent 6, optional)
# Get free key at: https://fal.ai/dashboard/keys
# Without this: Agent 6 skips gracefully, rest of pipeline runs normally
FAL_KEY=

# ─────────────────────────────────────────────
# Moki autonomy + budget
# Override autonomy level: 0=ask all, 1=trust me (default), 2=full
MOKI_AUTONOMY_LEVEL=1
# Override daily Claude budget cap (USD)
MOKI_DAILY_BUDGET=30
